# Pokémon - The Model Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# SUPABASE (Required for persistent storage)
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# POKEMON TCG API (Optional but recommended)
# ===========================================
# Get from: https://dev.pokemontcg.io/
# Without this, you're limited to 1,000 requests/hour
POKEMON_TCG_API_KEY=

# ===========================================
# OTHER SETTINGS
# ===========================================
# Cache TTL in hours (default: 24)
CACHE_TTL_HOURS=24
